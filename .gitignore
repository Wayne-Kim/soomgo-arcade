# Godot 4 import cache / editor state
.godot/

# Exported builds
build/
*.exe
*.pck
*.zip

# Design-validation spike: throwaway evidence renders (regenerated by run_spike.gd)
spikes/sprite_recolor/out/

# Sparkle GDExtension build inputs/outputs (built locally / in CI, not source). The committed
# template is sparkle_update.gdextension.disabled; the active .gdextension is created by renaming
# it after a local build, so it points at an ignored binary and must not be committed.
addons/sparkle_update/godot-cpp/
addons/sparkle_update/bin/
addons/sparkle_update/Sparkle/
addons/sparkle_update/Sparkle.framework/
addons/sparkle_update/sparkle_update.gdextension

# ── Secrets (배포 자격증명) — 절대 커밋 금지. 이 repo 는 곧 public 전환. ──
# 공증용 App Store Connect API 키(.p8) + asc-api-key.env, Sparkle EdDSA 개인키 등.
# secrets/ 안의 어떤 파일도 git 에 들어가면 안 된다. 커밋 전 `git status` 로 재확인.
secrets/
*.p8
*.mobileprovision
sparkle_private.key

# Godot 의 실제 export 프리셋은 codesign/apple_team_id(= Apple 개인/조직 식별자)를 담는다.
# 추적되는 건 team_id 를 비운 export_presets.cfg.example 뿐. 실제 파일은 deploy 스크립트가
# .example 에서 부트스트랩하거나 Godot 가 로컬에서 생성/갱신한다.
export_presets.cfg