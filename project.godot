; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Soomgo Arcade"
config/description="Grid-based water-balloon arena for 4-8 local players."
run/main_scene="res://scenes/Lobby.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

Strings="*res://scripts/ui/Strings.gd"
Audio="*res://scripts/audio/Audio.gd"
UpdateManager="*res://scripts/updates/UpdateManager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=800
window/stretch/mode="canvas_items"

[gui]

theme/custom="res://assets/theme.tres"

[input]

p1_up={
