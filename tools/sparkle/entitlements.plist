<?xml version="1.0" encoding="UTF-8"?>
<!--
  Hardened-runtime entitlements for the signed/notarized build. Required so notarization passes
  while the embedded Sparkle.framework (and the JIT-free Godot runtime) can load. Adjust to taste;
  network-client lets Sparkle download updates without its separate Downloader XPC service.
-->
<plist version="1.0">
<dict>
	<key>com.apple.security.app-sandbox</key>
	<false/>
	<key>com.apple.security.network.client</key>
	<true/>
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
</dict>
</plist>
